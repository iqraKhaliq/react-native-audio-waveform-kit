{
  "name": "react-native-audio-waveform-kit",
  "version": "1.0.2",
  "description": "WhatsApp‑style voice recording and playback waveforms for React Native (using react-native-audio-api)",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "bob build",
    "prepare": "bob build",
    "clean": "rm -rf lib",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "keywords": [
    "react-native",
    "audio",
    "waveform",
    "recording",
    "playback",
    "voice-message"
  ],
  "author": "Iqra Khaliq <iqra.khaliq459@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iqraKhaliq/react-native-audio-waveform-kit.git"
  },
  "homepage": "https://github.com/iqraKhaliq/react-native-audio-waveform-kit#readme",
  "bugs": {
    "url": "https://github.com/iqraKhaliq/react-native-audio-waveform-kit/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0",
    "react-native-audio-api": ">=0.12.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": "^4.3.1",
    "react-native-sound": "^0.13.0",
    "react-native-svg": ">=13.0.0",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-native": "^0.70.0",
    "prettier": "^3.8.3",
    "react-native-builder-bob": "^0.40.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
