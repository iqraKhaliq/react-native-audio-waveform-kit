{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "jsx": "react-native",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "lib/typescript",
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "lib",
    "**/__tests__",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ]
}
